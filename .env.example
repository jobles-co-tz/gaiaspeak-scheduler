# Server
PORT=4000
# Comma-separated list of allowed origins for CORS (e.g. http://localhost:5173,https://gaiaspeak.com)
CORS_ORIGIN=http://localhost:5173

# SMTP transport
# For Gmail, use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# From address shown to recipients
MAIL_FROM_NAME=GaiaSpeak
MAIL_FROM_EMAIL=no-reply@gaiaspeak.com

# Public base URL of the GaiaSpeak web app (used to build the supplier submission link)
FRONTEND_URL=http://localhost:5173

# Optional shared secret. When set, incoming requests must include `x-api-key` header matching this value.
API_KEY=

# Supabase (server-side, service role) — required for the scheduled supplier-email batch
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Override table names if yours differ
SUPPLIERS_TABLE=suppliers
AUDIT_LOGS_TABLE=audit_logs

# Scheduler
# Every 4 hours on the hour (standard 5-field cron). See https://crontab.guru
SCHEDULE_CRON=0 */4 * * *
SCHEDULE_ENABLED=true
# Optional IANA timezone (e.g. Europe/London). Defaults to server local time.
SCHEDULE_TZ=
# Run one batch immediately at startup (useful for testing, keep false in production)
SCHEDULE_RUN_ON_START=false

